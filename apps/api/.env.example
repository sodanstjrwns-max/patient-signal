# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/patient_signal?schema=public"
# Supabase 등 pgbouncer 사용 시 마이그레이션용 직접 연결 URL
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/patient_signal?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# AI APIs
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
PERPLEXITY_API_KEY="pplx-your-perplexity-api-key"
GEMINI_API_KEY="your-google-gemini-api-key"

# === NEW: 추가 AI 플랫폼 (백서 v2.0 — 6개 AI 커버) ===
# Grok (xAI) - 발급: https://console.x.ai/ → API Keys
# - 실시간 X(Twitter) 통합 + 웹검색 강점
# - 모델: grok-2-latest
XAI_API_KEY="xai-your-xai-api-key"

# CLOVA X (Naver) - 발급: https://www.ncloud.com/ → CLOVA Studio
# - 한국 토종 LLM 1위 후보, 한국어 쿼리 최적화
# - 모델: HCX-005
CLOVA_X_API_KEY="your-naver-clova-x-api-key"
# (선택) CLOVA X 커스텀 엔드포인트 (테스트앱 vs 서비스앱 분기)
# CLOVA_X_ENDPOINT="https://clovastudio.stream.ntruss.com/testapp/v3/chat-completions/HCX-005"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Toss Payments
TOSS_SECRET_KEY="your-toss-secret-key"
TOSS_WEBHOOK_SECRET="your-toss-webhook-secret"

# Email (Resend) — 가입 인증/결제 알림 메일 발송
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@patientsignal.kr"

# Google OAuth (소셜 로그인)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# 운영/보안 — 미설정 시 해당 엔드포인트 자체가 차단됨 (프로덕션 필수)
ADMIN_SECRET="change-me-strong-random-string"
ADMIN_EMAILS="admin@example.com"
CRON_SECRET="change-me-strong-random-string"

# Patient Pulse 외부 연동 (선택)
# PATIENT_PULSE_URL="https://patientpulse.kr"

# Grok 세부 설정 (선택)
# GROK_MODEL="grok-2-latest"
# GROK_SEARCH_MAX_RESULTS=10

# 크롤 큐 동시성 (선택, REDIS_URL 설정 시)
# CRAWL_QUEUE_CONCURRENCY=3

# ── 스케일 튜닝 (선택) — 수백~수천 클라이언트 대비 ──
# 인라인 크롤 모드(REDIS_URL 없을 때) 병원 동시 처리 수 (기본 4)
# HOSPITAL_CONCURRENCY=4
# Prisma DB 커넥션 풀 크기 (기본 15) — Supabase pooler/Neon 한도 내에서 조정
# 다중 인스턴스 운영 시: (인스턴스 수 × DB_CONNECTION_LIMIT) < DB max_connections 유지
# DB_CONNECTION_LIMIT=15
# 커넥션 대기 타임아웃 초 (기본 20)
# DB_POOL_TIMEOUT=20

# Server
PORT=4000
NODE_ENV=development
